<% const r = typeof room !== 'undefined' ? room : {}; %>
<% const brs = typeof branches !== 'undefined' ? branches : []; %>
<% const props = typeof properties !== 'undefined' ? properties : []; %>
<% const rts = typeof roomTypes !== 'undefined' ? roomTypes : []; %>
<% const statuses = typeof roomStatuses !== 'undefined' ? roomStatuses : []; %>
<% const isCreate = typeof mode !== 'undefined' && mode === 'create'; %>
<% const selectedBranchId = r.branchId || (typeof preselectBranchId !== 'undefined' ? preselectBranchId : ''); %>
<% const selectedBranch = brs.find(function(b) { return String(b.id) === String(selectedBranchId); }); %>
<% const selectedPropertyId = selectedBranch
  ? selectedBranch.propertyId
  : (typeof preselectPropertyId !== 'undefined' ? preselectPropertyId : ''); %>
<% const selectedRoomTypeId = r.roomTypeId || (typeof preselectRoomTypeId !== 'undefined' ? preselectRoomTypeId : ''); %>
<% const galleryUrls = Array.isArray(r.galleryImages) ? r.galleryImages.filter(Boolean) : []; %>
<% const extraParas = Array.isArray(r.extraParagraphs) ? r.extraParagraphs.filter(Boolean) : []; %>
<% const rtc = typeof roomTypeCatalog !== 'undefined' ? roomTypeCatalog : []; %>
<% function numField(val) {
  if (isCreate && (val === 0 || val === null || val === undefined)) return '';
  if (val === null || val === undefined) return '';
  return val;
} %>

<form method="POST" action="<%= formAction %>" class="admin-crud-form" id="roomForm">
  <% if (typeof formError !== 'undefined' && formError) { %>
  <div class="alert alert-danger"><%= formError %></div>
  <% } %>

  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card admin-card mb-4">
        <div class="card-header d-flex align-items-center justify-content-between">
          <strong>Thuộc chi nhánh nào?</strong>
          <span class="badge text-bg-light text-body-secondary fw-normal">Bắt buộc</span>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="filterPropertyId">Cơ sở lưu trú</label>
              <select class="form-select" id="filterPropertyId">
                <option value="">— Chọn cơ sở trước —</option>
                <% props.forEach(function(prop) { %>
                <option value="<%= prop.id %>" <%= String(selectedPropertyId) === String(prop.id) ? 'selected' : '' %>>
                  <%= prop.name %> · <%= prop.city %>
                </option>
                <% }); %>
              </select>
              <div class="form-text">Lọc danh sách chi nhánh bên dưới.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="branchId">Chi nhánh <span class="text-danger">*</span></label>
              <select class="form-select" id="branchId" name="branchId" required>
                <option value="">— Chọn chi nhánh —</option>
                <% brs.forEach(function(br) { %>
                <option
                  value="<%= br.id %>"
                  data-property-id="<%= br.propertyId %>"
                  data-code="<%= br.code %>"
                  data-name="<%= br.name %>"
                  data-property-name="<%= br.property?.name || '' %>"
                  <%= String(selectedBranchId) === String(br.id) ? 'selected' : '' %>
                ><%= br.property?.name ? br.property.name + ' → ' : '' %><%= br.name %> · <%= br.code %></option>
                <% }); %>
              </select>
              <div class="form-text">
                Phòng thuộc đúng một chi nhánh. Chưa có chi nhánh?
                <a href="/admin/branches/new" target="_blank" rel="noopener">Tạo chi nhánh</a>
              </div>
            </div>
          </div>

          <div id="branchPreview" class="admin-branch-property-preview rounded p-3 mt-3 <%= selectedBranch ? '' : 'd-none' %>">
            <div class="small text-body-secondary mb-1">Phòng sẽ thuộc</div>
            <div class="fw-semibold" id="branchPreviewPath">
              <% if (selectedBranch) { %>
              <%= selectedBranch.property?.name || 'Cơ sở' %> → <%= selectedBranch.name %>
              <% } %>
            </div>
            <code id="branchPreviewCode"><%= selectedBranch?.code || '' %></code>
          </div>
        </div>
      </div>

      <div class="card admin-card mb-4">
        <div class="card-header"><strong>Thông tin phòng</strong></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="roomTypeId">Loại phòng <span class="text-danger">*</span></label>
              <select class="form-select" id="roomTypeId" name="roomTypeId" required>
                <option value="">— Chọn loại phòng —</option>
                <% rts.forEach(function(rt) { %>
                <option value="<%= rt.id %>" <%= String(selectedRoomTypeId) === String(rt.id) ? 'selected' : '' %>><%= rt.title %> (<%= rt.category %>)</option>
                <% }); %>
              </select>
              <div class="form-text">
                Mẫu phòng (Standard, Deluxe…) — gallery & mô tả chi tiết.
                <a href="/admin/room-types" target="_blank" rel="noopener">Quản lý loại phòng</a>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label" for="code">Mã phòng <span class="text-danger">*</span></label>
              <input
                class="form-control"
                id="code"
                name="code"
                value="<%= r.code || '' %>"
                placeholder="HXH-101"
                required
              >
              <div class="form-text">Duy nhất trong chi nhánh. Thường: mã CN + số phòng (vd: <code>dl-hxh-101</code> hoặc <code>HXH-101</code>).</div>
            </div>
            <div class="col-md-4">
              <label class="form-label" for="priceVnd">Giá/đêm (VND) <span class="text-danger">*</span></label>
              <input
                class="form-control"
                type="number"
                min="0"
                step="1000"
                id="priceVnd"
                name="priceVnd"
                value="<%= numField(r.priceVnd) %>"
                placeholder="890000"
                required
              >
            </div>
            <div class="col-md-4">
              <label class="form-label" for="status">Trạng thái đặt</label>
              <select class="form-select" id="status" name="status">
                <% statuses.forEach(function(s) { %>
                <option value="<%= s.value %>" <%= (r.status || 'available') === s.value ? 'selected' : '' %>><%= s.label %></option>
                <% }); %>
              </select>
              <div class="form-text">Trạng thái vận hành nhanh — booking thật sẽ cập nhật tự động sau.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label" for="maxAdults">Số người lớn tối đa</label>
              <input class="form-control" type="number" min="1" id="maxAdults" name="maxAdults" value="<%= r.maxAdults ?? 2 %>">
            </div>
            <div class="col-md-4">
              <label class="form-label" for="maxChildren">Số trẻ em tối đa</label>
              <input class="form-control" type="number" min="0" id="maxChildren" name="maxChildren" value="<%= r.maxChildren ?? 0 %>">
            </div>
            <div class="col-12">
              <label class="form-label" for="description">Mô tả ngắn (dòng đầu trang chi tiết) <span class="text-danger">*</span></label>
              <textarea
                class="form-control"
                id="description"
                name="description"
                rows="2"
                required
                placeholder="Phòng 101 — tầng 1, view vườn"
              ><%= r.description || '' %></textarea>
              <div class="form-text">Hiển thị nổi bật đầu phần mô tả. Thêm đoạn bổ sung bên dưới.</div>
            </div>
            <div class="col-12">
              <label class="form-label" for="altText">Alt text ảnh (SEO / accessibility)</label>
              <input class="form-control" id="altText" name="altText" value="<%= r.altText || '' %>" placeholder="Phòng Standard view vườn — Cherry House Đà Lạt">
            </div>
          </div>
        </div>
      </div>

      <div class="card admin-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong>Ảnh trang chi tiết</strong>
          <span class="badge text-bg-light text-body-secondary fw-normal">Tối đa 5</span>
        </div>
        <div class="card-body">
          <p class="small text-body-secondary mb-3">
            Khách xem trên hero & lưới ảnh. Nếu không thêm ảnh nào → dùng <strong>ảnh đại diện</strong> (cột phải) rồi gallery <strong>loại phòng</strong>, cuối cùng là ảnh mặc định.
          </p>
          <div id="roomGalleryList" class="d-flex flex-column gap-3" data-max-rows="5">
            <% const galleryRows = galleryUrls.length ? galleryUrls : ['']; %>
            <% galleryRows.forEach(function(url, idx) { %>
            <div class="gallery-row border rounded p-3" data-gallery-row>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small fw-semibold" data-gallery-label>Ảnh <%= idx + 1 %></span>
                <button type="button" class="btn btn-outline-danger btn-sm" data-remove-gallery-row>×</button>
              </div>
              <%- include('galleryImagePicker', {
                fieldId: 'galleryImageUrl_' + idx,
                fieldName: 'galleryImageUrl[]',
                value: url,
                label: 'Ảnh chi tiết',
              }) %>
            </div>
            <% }); %>
          </div>
          <button type="button" class="btn btn-outline-primary btn-sm mt-3" id="addRoomGalleryRow">+ Thêm ảnh</button>
        </div>
      </div>

      <template id="roomGalleryRowTemplate">
        <div class="gallery-row border rounded p-3" data-gallery-row>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="small fw-semibold" data-gallery-label>Ảnh</span>
            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-gallery-row>×</button>
          </div>
          <div class="gallery-image-picker" data-gallery-picker>
            <label class="form-label">Ảnh chi tiết</label>
            <div class="gallery-image-picker-preview mb-2 d-none" data-gallery-picker-preview>
              <img src="" alt="" class="gallery-image-picker-thumb rounded border" data-gallery-picker-preview-img>
            </div>
            <input type="hidden" class="gallery-image-picker-input" name="galleryImageUrl[]" value="" data-gallery-picker-input>
            <div class="d-flex flex-wrap gap-2">
              <button type="button" class="btn btn-outline-primary btn-sm" data-gallery-picker-open>
                <i class="fa-solid fa-images me-1"></i>Chọn từ gallery
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm d-none" data-gallery-picker-clear>
                <i class="fa-solid fa-xmark me-1"></i>Xóa ảnh
              </button>
            </div>
            <div class="form-text" data-gallery-picker-path-text>Chưa chọn ảnh.</div>
          </div>
        </div>
      </template>

      <div class="card admin-card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong>Mô tả bổ sung</strong>
          <button type="button" class="btn btn-outline-primary btn-sm" id="addExtraParagraphRow">+ Đoạn văn</button>
        </div>
        <div class="card-body">
          <p class="small text-body-secondary mb-3">Các đoạn thêm sau mô tả ngắn — cộng với mô tả từ <strong>loại phòng</strong>.</p>
          <div id="extraParagraphList" class="d-flex flex-column gap-3">
            <% const paraRows = extraParas.length ? extraParas : []; %>
            <% if (!paraRows.length) { %>
            <div class="extra-paragraph-row" data-extra-paragraph-row>
              <div class="input-group">
                <textarea class="form-control" name="extraParagraph[]" rows="2" placeholder="Không gian rộng, ban công nhìn vườn..."></textarea>
                <button type="button" class="btn btn-outline-danger" data-remove-extra-paragraph-row>×</button>
              </div>
            </div>
            <% } %>
            <% paraRows.forEach(function(p) { %>
            <div class="extra-paragraph-row" data-extra-paragraph-row>
              <div class="input-group">
                <textarea class="form-control" name="extraParagraph[]" rows="2" placeholder="Không gian rộng, ban công nhìn vườn..."><%= p %></textarea>
                <button type="button" class="btn btn-outline-danger" data-remove-extra-paragraph-row>×</button>
              </div>
            </div>
            <% }); %>
          </div>
        </div>
      </div>

      <template id="extraParagraphRowTemplate">
        <div class="extra-paragraph-row" data-extra-paragraph-row>
          <div class="input-group">
            <textarea class="form-control" name="extraParagraph[]" rows="2" placeholder="Không gian rộng, ban công nhìn vườn..."></textarea>
            <button type="button" class="btn btn-outline-danger" data-remove-extra-paragraph-row>×</button>
          </div>
        </div>
      </template>
    </div>

    <div class="col-lg-4">
      <div class="card admin-card mb-4" id="roomTypePreviewCard">
        <div class="card-header d-flex justify-content-between align-items-center">
          <strong>Tổng quan từ loại phòng</strong>
          <a href="/admin/room-types" id="roomTypeEditLink" class="btn btn-link btn-sm" target="_blank" rel="noopener">Sửa loại</a>
        </div>
        <div class="card-body small" id="roomTypePreviewBody">
          <p class="text-body-secondary mb-0">Chọn loại phòng để xem diện tích, giường, tiện nghi…</p>
        </div>
      </div>

      <div class="card admin-card mb-4">
        <div class="card-header"><strong>Ảnh đại diện (danh sách đặt phòng)</strong></div>
        <div class="card-body">
          <div class="mb-3">
            <%- include('galleryImagePicker', {
              fieldId: 'imageUrl',
              fieldName: 'imageUrl',
              value: r.imageUrl || '',
              label: 'Thumbnail phòng',
            }) %>
            <div class="form-text mt-1">Dùng khi chưa có gallery chi tiết — hiển thị ở bước chọn phòng.</div>
          </div>
          <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="on" <%= r.isActive !== false ? 'checked' : '' %>>
            <label class="form-check-label" for="isActive">Hiển thị trên website (Active)</label>
          </div>
          <div class="form-text">Tắt để ẩn phòng khỏi web khách.</div>
        </div>
      </div>

      <% if (typeof previewUrl !== 'undefined' && previewUrl) { %>
      <div class="card admin-card mb-4 border-primary border-opacity-25">
        <div class="card-header"><strong>Xem trước trang chi tiết</strong></div>
        <div class="card-body">
          <p class="small text-body-secondary mb-3">Mở trang chi tiết phòng trên website (tab mới).</p>
          <a href="<%= previewUrl %>" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm w-100">
            <i class="fa-solid fa-up-right-from-square me-1"></i> Xem chi tiết phòng
          </a>
        </div>
      </div>
      <% } %>

      <div class="d-grid gap-2">
        <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
        <a href="/admin/rooms" class="btn btn-outline-secondary">Hủy</a>
      </div>
    </div>
  </div>
</form>

<script type="application/json" id="roomTypeCatalogData"><%- JSON.stringify(rtc.map(function(rt) {
  return {
    id: rt.id,
    title: rt.title,
    badge: rt.badge,
    areaSqm: rt.areaSqm,
    bedLabel: rt.bedLabel,
    capacityLabel: rt.capacityLabel,
    checkInTime: rt.checkInTime,
    checkOutTime: rt.checkOutTime,
    paragraphs: Array.isArray(rt.paragraphs) ? rt.paragraphs : [],
    policyBullets: Array.isArray(rt.policyBullets) ? rt.policyBullets : [],
    amenities: (rt.amenities || []).map(function(row) {
      return row.amenity ? row.amenity.label : '';
    }).filter(Boolean),
    galleryCount: (rt.gallery || []).length,
  };
})) %></script>

<script src="/admin/js/admin-room-form.js"></script>
<script>
  (function roomFormBranchCascade() {
    const propertySelect = document.getElementById('filterPropertyId');
    const branchSelect = document.getElementById('branchId');
    const preview = document.getElementById('branchPreview');
    const pathEl = document.getElementById('branchPreviewPath');
    const codeEl = document.getElementById('branchPreviewCode');
    const codeInput = document.getElementById('code');
    if (!branchSelect) return;

    const allBranchOptions = Array.from(branchSelect.options).slice(1);

    function updateBranchPreview() {
      const opt = branchSelect.selectedOptions[0];
      if (!opt || !opt.value) {
        preview?.classList.add('d-none');
        return;
      }
      preview?.classList.remove('d-none');
      const propName = opt.dataset.propertyName || 'Cơ sở';
      if (pathEl) pathEl.textContent = propName + ' → ' + (opt.dataset.name || opt.textContent);
      if (codeEl) codeEl.textContent = opt.dataset.code || '';
      if (codeInput && !codeInput.value.trim() && opt.dataset.code) {
        const prefix = opt.dataset.code.toUpperCase().replace(/-/g, '');
        codeInput.placeholder = prefix + '-101';
      }
    }

    function syncBranches() {
      const propertyId = propertySelect?.value || '';
      const current = branchSelect.value;
      branchSelect.innerHTML = '<option value="">— Chọn chi nhánh —</option>';
      allBranchOptions.forEach((opt) => {
        if (!propertyId || opt.dataset.propertyId === propertyId) {
          branchSelect.appendChild(opt.cloneNode(true));
        }
      });
      const stillValid = Array.from(branchSelect.options).some((o) => o.value === current);
      branchSelect.value = stillValid ? current : '';
      updateBranchPreview();
    }

    propertySelect?.addEventListener('change', syncBranches);
    branchSelect.addEventListener('change', updateBranchPreview);
    syncBranches();
  })();
</script>
