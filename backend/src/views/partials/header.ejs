<header class="header header-sticky p-0 admin-header-shell">
  <div class="container-fluid border-bottom px-4">
    <button class="header-toggler px-md-2" type="button" onclick="coreui.Sidebar.getInstance(document.querySelector('#sidebar')).toggle()" aria-label="Thu mở sidebar">
      <svg class="icon icon-lg"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-menu"></use></svg>
    </button>
    <ul class="header-nav d-none d-lg-flex">
      <li class="nav-item"><a class="nav-link" href="/admin">Dashboard</a></li>
    </ul>
    <ul class="header-nav ms-auto"></ul>
    <ul class="header-nav">
      <li class="nav-item py-1 d-flex align-items-center">
        <div class="vr align-self-stretch mx-2 my-2 text-body text-opacity-75" style="min-height:1.5rem;"></div>
      </li>
      <li class="nav-item dropdown py-1 d-flex align-items-center admin-header-theme">
        <button class="btn btn-link nav-link py-1 px-2 d-inline-flex align-items-center justify-content-center admin-header-theme-btn" type="button" aria-expanded="false" data-coreui-toggle="dropdown" aria-label="Giao diện sáng / tối">
          <svg class="icon icon-lg theme-icon-active"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-contrast"></use></svg>
        </button>
        <ul class="dropdown-menu dropdown-menu-end" style="--cui-dropdown-min-width: 10rem;">
          <li><button class="dropdown-item d-flex align-items-center" type="button" data-coreui-theme-value="light"><svg class="icon icon-lg me-3"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-sun"></use></svg>Sáng</button></li>
          <li><button class="dropdown-item d-flex align-items-center" type="button" data-coreui-theme-value="dark"><svg class="icon icon-lg me-3"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-moon"></use></svg>Tối</button></li>
          <li><button class="dropdown-item d-flex align-items-center active" type="button" data-coreui-theme-value="auto"><svg class="icon icon-lg me-3"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-contrast"></use></svg>Theo hệ thống</button></li>
        </ul>
      </li>
      <li class="nav-item py-1 d-flex align-items-center">
        <div class="vr align-self-stretch mx-2 my-2 text-body text-opacity-75" style="min-height:1.5rem;"></div>
      </li>
      <li class="nav-item dropdown py-1 d-flex align-items-center admin-header-user">
        <a class="nav-link d-flex align-items-center gap-2 py-1 ps-2 pe-2 rounded-2 admin-header-user-trigger" data-coreui-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false" aria-label="Menu tài khoản">
          <span class="avatar avatar-md admin-header-avatar">
            <img class="avatar-img" src="<%= (typeof user !== 'undefined' && user && user.avatar && String(user.avatar).trim()) ? '/' + String(user.avatar).replace(/^\/+/, '') : '/coreui/assets/img/avatars/8.jpg' %>" alt="">
          </span>
          <i class="fa-solid fa-chevron-down admin-header-user-chevron" aria-hidden="true"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end pt-0" style="--cui-dropdown-min-width: 15rem;">
          <div class="dropdown-header bg-body-tertiary text-body-secondary fw-semibold rounded-top mb-0 py-3">
            <% if (typeof user !== 'undefined' && user && user.email) { %>
            <div class="small text-truncate" style="max-width: 14rem;"><%= user.email %></div>
            <div class="small mt-1 d-flex flex-wrap gap-1">
              <span class="badge text-bg-secondary"><%=
                user.role === 'super_admin' ? 'Super Admin'
                : user.role === 'admin' ? 'Admin'
                : user.role === 'staff' ? 'Nhân viên'
                : (user.role || '')
              %></span>
              <% if (typeof isStaff !== 'undefined' && isStaff && user.branchName) { %>
              <span class="badge text-bg-info"><%= user.branchName %></span>
              <% } %>
            </div>
            <% } else { %>
            <div class="small text-truncate" style="max-width: 14rem;">Admin</div>
            <% } %>
          </div>
          <a class="dropdown-item d-flex align-items-center gap-2" href="/" target="_blank" rel="noopener">
            <svg class="icon flex-shrink-0"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-external-link"></use></svg>
            <span>Mở website</span>
          </a>
          <div class="dropdown-divider my-1"></div>
          <button type="button" class="btn btn-outline-danger btn-sm w-100 mx-3 mb-2 d-flex align-items-center justify-content-center gap-2" style="width:calc(100% - 1.5rem) !important;" onclick="AdminAuth.logout()">
            <svg class="icon"><use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-account-logout"></use></svg>
            Đăng xuất
          </button>
        </div>
      </li>
    </ul>
  </div>
  <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs.length) { %>
  <div class="container-fluid px-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb my-0">
        <% breadcrumbs.forEach(function(crumb, index) { %>
          <% if (index === breadcrumbs.length - 1 || !crumb.href) { %>
            <li class="breadcrumb-item active"><span><%= crumb.label %></span></li>
          <% } else { %>
            <li class="breadcrumb-item"><a href="<%= crumb.href %>"><%= crumb.label %></a></li>
          <% } %>
        <% }); %>
      </ol>
    </nav>
  </div>
  <% } %>
</header>
