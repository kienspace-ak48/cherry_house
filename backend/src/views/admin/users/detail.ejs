<div class="admin-page-head d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h2><%= user.fullName %></h2>
    <p class="text-body-secondary mb-0 small">
      <%= user.email %> · Đăng ký <%= formatDateTime(user.createdAt) %>
    </p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a href="/admin/users" class="btn btn-outline-secondary btn-sm">← Danh sách</a>
    <a href="/admin/users/<%= user.id %>/edit" class="btn btn-primary btn-sm">Sửa tài khoản</a>
    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
    <form
      method="POST"
      action="/admin/users/<%= user.id %>/delete"
      class="d-inline"
      onsubmit="return confirm('Xóa vĩnh viễn <%= user.fullName %>?');"
    >
      <button type="submit" class="btn btn-outline-danger btn-sm">Xóa tài khoản</button>
    </form>
    <% } %>
  </div>
</div>

<% if (typeof flash !== 'undefined' && flash === 'updated') { %><div class="alert alert-success">Đã cập nhật tài khoản.</div><% } %>
<% if (typeof flash !== 'undefined' && flash === 'wallet_updated') { %><div class="alert alert-success">Đã cập nhật số dư ví.</div><% } %>
<% if (typeof flash !== 'undefined' && flash === 'error') { %><div class="alert alert-danger"><%= msg || 'Có lỗi' %></div><% } %>

<% if (user.bookingBanned) { %>
<div class="alert alert-danger mb-4">
  <strong>Cấm đặt phòng</strong>
  <% if (user.bookingBannedAt) { %> · từ <%= formatDateTime(user.bookingBannedAt) %><% } %>
  <% if (user.bookingBanReason) { %>
  <p class="mb-0 mt-2 small"><%= user.bookingBanReason %></p>
  <% } else { %>
  <p class="mb-0 mt-2 small">Khách vẫn có thể đăng nhập nhưng không thể tạo booking mới.</p>
  <% } %>
</div>
<% } %>

<div class="row g-4">
  <div class="col-lg-5">
    <div class="card admin-card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Thông tin</strong>
        <% if (user.isActive) { %>
        <span class="badge bg-success">Active</span>
        <% } else { %>
        <span class="badge bg-danger">Đã khóa</span>
        <% } %>
      </div>
      <div class="card-body">
        <% if (user.avatarUrl) { %>
        <div class="mb-3 text-center">
          <img src="<%= user.avatarUrl %>" alt="" class="rounded-circle" width="72" height="72" referrerpolicy="no-referrer">
        </div>
        <% } %>
        <dl class="row mb-0 small">
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><a href="mailto:<%= user.email %>"><%= user.email %></a></dd>
          <dt class="col-sm-4">Điện thoại</dt>
          <dd class="col-sm-8"><%= user.phone || '—' %></dd>
          <dt class="col-sm-4">Đăng nhập</dt>
          <dd class="col-sm-8"><%= authProviderLabel(user.authProvider) %></dd>
          <dt class="col-sm-4">Email xác thực</dt>
          <dd class="col-sm-8"><%= user.emailVerified ? 'Có' : 'Chưa' %></dd>
          <dt class="col-sm-4">Hạng thành viên</dt>
          <dd class="col-sm-8"><%= tierLabel(user.membershipTier) %></dd>
          <dt class="col-sm-4">Đặt phòng</dt>
          <dd class="col-sm-8">
            <% if (user.bookingBanned) { %>
            <span class="text-danger fw-semibold">Bị cấm</span>
            <% } else { %>
            <span class="text-success">Được phép</span>
            <% } %>
          </dd>
          <dt class="col-sm-4">Tổng booking</dt>
          <dd class="col-sm-8"><%= user._count?.bookings ?? 0 %></dd>
          <dt class="col-sm-4">Cập nhật</dt>
          <dd class="col-sm-8"><%= formatDateTime(user.updatedAt) %></dd>
        </dl>
      </div>
    </div>

    <% if (typeof walletSummary !== 'undefined' && walletSummary) { %>
    <div class="card admin-card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Ví Cherry House</strong>
        <span class="badge bg-success fs-6"><%= formatVnd(walletSummary.balanceVnd) %></span>
      </div>
      <div class="card-body">
        <% if (typeof isAdminManager !== 'undefined' && isAdminManager) { %>
        <form method="POST" action="/admin/users/<%= user.id %>/wallet-adjust" class="row g-2 mb-3">
          <div class="col-12">
            <label class="form-label small mb-1" for="walletAmount">Điều chỉnh số dư (VND, âm = trừ)</label>
            <input class="form-control form-control-sm" type="number" id="walletAmount" name="amountVnd" step="1000" required>
          </div>
          <div class="col-12">
            <input class="form-control form-control-sm" type="text" name="note" placeholder="Ghi chú (tuỳ chọn)">
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-outline-primary btn-sm" onclick="return confirm('Xác nhận điều chỉnh ví?');">Cập nhật ví</button>
          </div>
        </form>
        <% } %>
        <% if (walletSummary.recentTransactions.length) { %>
        <div class="table-responsive">
          <table class="table table-sm mb-0">
            <thead><tr><th>Thời gian</th><th>Loại</th><th class="text-end">Số tiền</th></tr></thead>
            <tbody>
              <% walletSummary.recentTransactions.forEach(function(tx) { %>
              <tr>
                <td><small><%= formatDateTime(tx.createdAt) %></small></td>
                <td><small><%= tx.type %><% if (tx.bookingCode) { %> · <code><%= tx.bookingCode %></code><% } %></small></td>
                <td class="text-end <%= tx.amountVnd >= 0 ? 'text-success' : 'text-danger' %>"><%= tx.amountVnd >= 0 ? '+' : '' %><%= formatVnd(Math.abs(tx.amountVnd)) %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <p class="small text-body-secondary mb-0">Chưa có giao dịch ví.</p>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>

  <div class="col-lg-7">
    <% if (typeof checkInHistory !== 'undefined' && checkInHistory.length) { %>
    <div class="card admin-card mb-4">
      <div class="card-header"><strong>Lịch sử check-in &amp; chữ ký</strong></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Thời gian</th>
                <th>Mã / Phòng</th>
                <th>Cơ sở</th>
                <th>Chữ ký</th>
              </tr>
            </thead>
            <tbody>
              <% checkInHistory.forEach(function(row) { %>
              <tr>
                <td><small><%= formatDateTime(row.checkedInAt) %></small>
                  <% if (row.staffName) { %><br><small class="text-body-secondary">NV: <%= row.staffName %></small><% } %>
                </td>
                <td>
                  <a href="/admin/bookings/<%= row.bookingId %>"><code><%= row.bookingCode %></code></a>
                  <br><small><%= row.roomCode %></small>
                </td>
                <td><small><%= row.propertyName %><br><%= row.branchName %></small></td>
                <td>
                  <a href="<%= row.signatureUrl %>" target="_blank" rel="noopener" title="Xem chữ ký">
                    <img src="<%= row.signatureUrl %>" alt="Chữ ký" width="72" height="48" class="border rounded bg-white" style="object-fit:contain;">
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>

    <div class="card admin-card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <strong>Lịch sử đặt phòng</strong>
        <a href="/admin/bookings?userId=<%= user.id %>" class="small">Xem tất cả →</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Mã</th>
                <th>Phòng</th>
                <th>Ngày</th>
                <th>Tổng</th>
                <th>TT</th>
              </tr>
            </thead>
            <tbody>
              <% if (!bookings.length) { %>
              <tr><td colspan="5" class="text-center text-body-secondary py-4">Chưa có booking</td></tr>
              <% } else { bookings.slice(0, 10).forEach(function(b) { %>
              <tr>
                <td><a href="/admin/bookings/<%= b.id %>"><code><%= b.bookingCode %></code></a></td>
                <td><%= b.roomCode %><br><small class="text-body-secondary"><%= b.propertyName %></small></td>
                <td><small><%= b.checkIn %> → <%= b.checkOut %></small></td>
                <td><%= formatVnd(b.totalVnd) %></td>
                <td><span class="badge bg-secondary"><%= b.status %></span></td>
              </tr>
              <% }); } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
