<div class="admin-page-head d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h2>Mã giảm giá</h2>
    <p class="text-body-secondary mb-0 small">
      Quản lý coupon — khách nhập mã tại trang thanh toán. Giảm % hoặc số tiền cố định (toàn hệ thống).
    </p>
  </div>
  <a href="/admin/promo-codes/new" class="btn btn-primary btn-sm">+ Thêm mã</a>
</div>

<% if (typeof flash !== 'undefined' && flash === 'created') { %>
<div class="alert alert-success">Đã tạo mã giảm giá.</div>
<% } else if (flash === 'updated') { %>
<div class="alert alert-success">Đã cập nhật mã giảm giá.</div>
<% } else if (flash === 'deleted') { %>
<div class="alert alert-success">Đã xóa mã giảm giá.</div>
<% } else if (flash === 'notfound') { %>
<div class="alert alert-warning">Không tìm thấy mã.</div>
<% } else if (flash === 'error' && typeof msg !== 'undefined' && msg) { %>
<div class="alert alert-danger"><%= msg %></div>
<% } %>
<% if (typeof formError !== 'undefined' && formError) { %>
<div class="alert alert-danger"><%= formError %></div>
<% } %>

<div class="card admin-card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Mã</th>
          <th>Giảm</th>
          <th>Hiệu lực</th>
          <th>Lượt dùng</th>
          <th>Đơn tối thiểu</th>
          <th>Trạng thái</th>
          <th class="text-end">Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% if (!promos.length) { %>
        <tr>
          <td colspan="7" class="text-center text-body-secondary py-5">
            Chưa có mã. <a href="/admin/promo-codes/new">Tạo mã đầu tiên</a>
          </td>
        </tr>
        <% } %>
        <% promos.forEach(function(p) { %>
        <tr>
          <td>
            <code class="fw-semibold"><%= p.code %></code>
            <% if (p.description) { %>
            <div class="small text-body-secondary"><%= p.description %></div>
            <% } %>
          </td>
          <td><%= discountLabel(p) %></td>
          <td class="small">
            <%= formatDateInput(p.validFrom) %> → <%= formatDateInput(p.validTo) %>
          </td>
          <td class="small">
            <%= p.usedCount %><% if (p.maxUses) { %> / <%= p.maxUses %><% } else { %> / ∞<% } %>
          </td>
          <td class="small"><%= formatPriceVnd(p.minSubtotalVnd) %> ₫</td>
          <td>
            <% if (p.isActive) { %>
            <span class="badge text-bg-success">Active</span>
            <% } else { %>
            <span class="badge text-bg-secondary">Tắt</span>
            <% } %>
          </td>
          <td class="text-end text-nowrap">
            <a href="/admin/promo-codes/<%= p.id %>/edit" class="btn btn-outline-primary btn-sm">Sửa</a>
            <form method="POST" action="/admin/promo-codes/<%= p.id %>/delete" class="d-inline" onsubmit="return confirm('Xóa mã <%= p.code %>?');">
              <button type="submit" class="btn btn-outline-danger btn-sm">Xóa</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
