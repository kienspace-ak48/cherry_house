<script>
  (function dashboardPage() {
    const CHART_COLORS = {
      primary: 'rgba(168, 46, 66, 0.85)',
      primaryLight: 'rgba(168, 46, 66, 0.55)',
      success: 'rgba(25, 135, 84, 0.85)',
      info: 'rgba(13, 202, 240, 0.85)',
      warning: 'rgba(255, 193, 7, 0.9)',
      danger: 'rgba(220, 53, 69, 0.85)',
      secondary: 'rgba(108, 117, 125, 0.75)',
      purple: 'rgba(111, 66, 193, 0.85)',
      teal: 'rgba(32, 201, 151, 0.85)',
    };

    const STATUS_COLORS = [
      CHART_COLORS.success,
      CHART_COLORS.warning,
      CHART_COLORS.info,
      CHART_COLORS.primary,
      CHART_COLORS.danger,
      CHART_COLORS.secondary,
      'rgba(173, 181, 189, 0.7)',
    ];

    const PAYMENT_COLORS = [
      CHART_COLORS.primary,
      CHART_COLORS.info,
      CHART_COLORS.success,
      CHART_COLORS.warning,
      CHART_COLORS.teal,
    ];

    let chartInstance = null;
    const analyticsCharts = {};
    let currentPeriod = 'week';

    function bookingStatusLabel(status) {
      const map = {
        pending_payment: 'Chờ thanh toán',
        confirmed: 'Đã xác nhận',
        cancelled: 'Đã hủy',
        completed: 'Hoàn tất',
      };
      return map[status] || status;
    }

    function renderMovementRow(b) {
      const href = `/admin/bookings?code=${encodeURIComponent(b.bookingCode)}`;
      return `
        <tr>
          <td><a href="${href}"><strong>${b.bookingCode}</strong></a></td>
          <td>${b.guestName || '—'}<br><small class="text-body-secondary">${b.guestPhone || ''}</small></td>
          <td>
            <strong>${b.roomCode}</strong><br>
            <small class="text-body-secondary">${b.propertyName} · ${b.branchName}</small>
          </td>
          <td><span class="badge bg-${AdminApi.statusBadge(b.status)}">${bookingStatusLabel(b.status)}</span></td>
        </tr>`;
    }

    function renderMovementTable(rows, tbodyId, badgeId) {
      document.getElementById(badgeId).textContent = rows.length;
      document.getElementById(tbodyId).innerHTML = rows.length
        ? rows.map(renderMovementRow).join('')
        : '<tr><td colspan="4" class="text-center text-body-secondary py-4">Không có lịch trình hôm nay</td></tr>';
    }

    function renderAlerts(alerts) {
      document.getElementById('badge-alert-count').textContent = alerts.length;
      const body = document.getElementById('dash-alerts-body');
      if (!alerts.length) {
        body.innerHTML = '<div class="text-center text-body-secondary py-4">Không có cảnh báo</div>';
        return;
      }
      body.innerHTML = `
        <div class="list-group list-group-flush">
          ${alerts.map((a) => {
            const b = a.booking;
            const href = `/admin/bookings?code=${encodeURIComponent(b.bookingCode)}`;
            return `
              <div class="list-group-item dashboard-alert-item dashboard-alert-${a.severity}">
                <div class="d-flex flex-wrap justify-content-between gap-2">
                  <div>
                    <span class="badge bg-${a.severity === 'danger' ? 'danger' : 'warning'} me-2">${a.title}</span>
                    <span>${a.message}</span>
                  </div>
                  <a href="${href}" class="small text-nowrap">${b.bookingCode} →</a>
                </div>
                <small class="text-body-secondary d-block mt-1">
                  ${b.guestName || '—'} · ${b.roomCode} · ${b.propertyName}
                </small>
              </div>`;
          }).join('')}
        </div>`;
    }

    function destroyChart(key) {
      if (analyticsCharts[key]) {
        analyticsCharts[key].destroy();
        delete analyticsCharts[key];
      }
    }

    function renderDoughnutChart(canvasId, key, labels, values, colors, tooltipFormat) {
      const canvas = document.getElementById(canvasId);
      if (!canvas || typeof Chart === 'undefined') return;
      destroyChart(key);
      const wrap = canvas.parentElement;
      if (!labels.length) {
        destroyChart(key);
        canvas.style.display = 'none';
        let empty = wrap.querySelector('.dash-chart-empty');
        if (!empty) {
          empty = document.createElement('p');
          empty.className = 'dash-chart-empty text-center text-body-secondary py-5 mb-0';
          empty.textContent = 'Chưa có dữ liệu';
          wrap.appendChild(empty);
        }
        return;
      }
      canvas.style.display = '';
      const emptyEl = wrap.querySelector('.dash-chart-empty');
      if (emptyEl) emptyEl.remove();
      analyticsCharts[key] = new Chart(canvas, {
        type: 'doughnut',
        data: {
          labels,
          datasets: [{
            data: values,
            backgroundColor: colors.slice(0, values.length),
            borderWidth: 1,
            borderColor: '#fff',
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } },
            tooltip: {
              callbacks: {
                label(ctx) {
                  const val = ctx.raw;
                  if (tooltipFormat === 'vnd') return ` ${AdminApi.formatVnd(val)}`;
                  return ` ${val}`;
                },
              },
            },
          },
        },
      });
    }

    function renderAnalyticsCharts(analytics, period) {
      if (!analytics) return;

      const periodHint = {
        day: '7 ngày gần nhất',
        week: '8 tuần gần nhất',
        month: '12 tháng gần nhất',
      };
      document.getElementById('dash-analytics-period-hint').textContent =
        `Booking & doanh thu: ${periodHint[period] || periodHint.week} · Công suất: 14 ngày`;

      renderDoughnutChart(
        'dash-chart-status',
        'status',
        analytics.bookingStatus?.labels || [],
        analytics.bookingStatus?.values || [],
        STATUS_COLORS,
        'count',
      );

      renderDoughnutChart(
        'dash-chart-payment',
        'payment',
        analytics.paymentMethods?.labels || [],
        analytics.paymentMethods?.revenueVnd || [],
        PAYMENT_COLORS,
        'vnd',
      );

      const occCanvas = document.getElementById('dash-chart-occupancy');
      if (occCanvas && typeof Chart !== 'undefined') {
        destroyChart('occupancy');
        const occ = analytics.occupancyTrend || { labels: [], rates: [] };
        analyticsCharts.occupancy = new Chart(occCanvas, {
          type: 'line',
          data: {
            labels: occ.labels,
            datasets: [{
              label: 'Công suất (%)',
              data: occ.rates,
              borderColor: CHART_COLORS.primary,
              backgroundColor: CHART_COLORS.primaryLight,
              fill: true,
              tension: 0.35,
              pointRadius: 2,
            }],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              y: {
                beginAtZero: true,
                max: 100,
                ticks: { callback: (v) => `${v}%` },
              },
            },
          },
        });
      }

      const propCanvas = document.getElementById('dash-chart-property');
      if (propCanvas && typeof Chart !== 'undefined') {
        destroyChart('property');
        const prop = analytics.propertyRevenue || { labels: [], revenueVnd: [] };
        analyticsCharts.property = new Chart(propCanvas, {
          type: 'bar',
          data: {
            labels: prop.labels,
            datasets: [{
              label: 'Doanh thu',
              data: prop.revenueVnd,
              backgroundColor: CHART_COLORS.primaryLight,
              borderColor: CHART_COLORS.primary,
              borderWidth: 1,
            }],
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label(ctx) {
                    return ` ${AdminApi.formatVnd(ctx.raw)}`;
                  },
                },
              },
            },
            scales: { x: { beginAtZero: true } },
          },
        });
      }

      const webCanvas = document.getElementById('dash-chart-website');
      if (webCanvas && typeof Chart !== 'undefined') {
        destroyChart('website');
        const web = analytics.websiteActivity || { labels: [], contactMessages: [], newUsers: [] };
        analyticsCharts.website = new Chart(webCanvas, {
          type: 'bar',
          data: {
            labels: web.labels,
            datasets: [
              {
                label: 'Tin liên hệ',
                data: web.contactMessages,
                backgroundColor: CHART_COLORS.info,
              },
              {
                label: 'Khách mới',
                data: web.newUsers,
                backgroundColor: CHART_COLORS.success,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom' } },
            scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
          },
        });
      }
    }

    function renderChart(chart) {
      const canvas = document.getElementById('dashboard-booking-chart');
      if (!canvas || typeof Chart === 'undefined') return;

      if (chartInstance) {
        chartInstance.destroy();
      }

      chartInstance = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: chart.labels,
          datasets: [
            {
              label: 'Số booking',
              data: chart.bookings,
              backgroundColor: 'rgba(13, 110, 253, 0.55)',
              borderColor: 'rgb(13, 110, 253)',
              borderWidth: 1,
              yAxisID: 'y',
            },
            {
              label: 'Doanh thu (triệu VND)',
              data: chart.revenueVnd.map((v) => Math.round(v / 1_000_000)),
              type: 'line',
              borderColor: 'rgb(25, 135, 84)',
              backgroundColor: 'rgba(25, 135, 84, 0.15)',
              tension: 0.3,
              yAxisID: 'y1',
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'bottom' },
            tooltip: {
              callbacks: {
                label(ctx) {
                  if (ctx.dataset.label.includes('Doanh thu')) {
                    const idx = ctx.dataIndex;
                    const raw = chart.revenueVnd[idx] || 0;
                    return `Doanh thu: ${AdminApi.formatVnd(raw)}`;
                  }
                  return `${ctx.dataset.label}: ${ctx.formattedValue}`;
                },
              },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              position: 'left',
              title: { display: true, text: 'Booking' },
              ticks: { precision: 0 },
            },
            y1: {
              beginAtZero: true,
              position: 'right',
              grid: { drawOnChartArea: false },
              title: { display: true, text: 'Triệu VND' },
            },
          },
        },
      });
    }

    function applyDashboard(data) {
      const {
        todayStats,
        catalog,
        chart,
        analytics,
        movements,
        alerts,
        recentProperties,
        asOf,
        today,
      } = data;

      document.getElementById('dash-as-of').textContent = `Cập nhật ${new Date(asOf).toLocaleString('vi-VN')} · ${today}`;
      document.getElementById('stat-bookings-today').textContent = todayStats.bookingsCreated;
      document.getElementById('stat-revenue-today').textContent = AdminApi.formatVnd(todayStats.revenueVnd);
      document.getElementById('stat-rooms-available').textContent = todayStats.roomsAvailable;
      document.getElementById('stat-rooms-occupied').textContent = todayStats.roomsOccupied;
      document.getElementById('stat-rooms-total').textContent = `Tổng ${todayStats.roomsTotal} phòng active`;

      document.getElementById('stat-properties').textContent = catalog.properties;
      document.getElementById('stat-branches').textContent = catalog.branches;
      document.getElementById('stat-rooms').textContent = catalog.rooms;
      document.getElementById('stat-bookings').textContent = catalog.bookingsTotal;

      renderChart(chart);
      renderAnalyticsCharts(analytics, chart?.period || currentPeriod);
      renderMovementTable(movements.checkInsToday, 'checkin-today-body', 'badge-checkin-count');
      renderMovementTable(movements.checkOutsToday, 'checkout-today-body', 'badge-checkout-count');
      renderAlerts(alerts);

      document.getElementById('recent-properties').innerHTML = recentProperties.length
        ? recentProperties.map((p) => `
          <tr>
            <td><strong>${p.name}</strong><br><small class="text-body-secondary">${p.slug}</small></td>
            <td>${p.city}</td>
            <td><span class="badge badge-kind-${p.kind}">${AdminApi.kindLabel(p.kind)}</span></td>
            <td>${AdminApi.formatVnd(p.priceFromVnd)}</td>
            <td>${p.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Off</span>'}</td>
          </tr>`).join('')
        : '<tr><td colspan="5" class="text-center text-body-secondary py-4">Chưa có dữ liệu</td></tr>';
    }

    async function loadDashboard(period) {
      currentPeriod = period || currentPeriod;
      const data = await AdminApi.getDashboardOverview(currentPeriod);
      applyDashboard(data);
    }

    document.querySelectorAll('.dash-period-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        document.querySelectorAll('.dash-period-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        try {
          await loadDashboard(btn.dataset.period);
        } catch (err) {
          AdminApi.showError(document.getElementById('dash-error'), err);
        }
      });
    });

    (async function init() {
      try {
        await loadDashboard('week');
      } catch (err) {
        AdminApi.showError(document.getElementById('dash-error'), err);
      }
    })();
  })();
</script>
