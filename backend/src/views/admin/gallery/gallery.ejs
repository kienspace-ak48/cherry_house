<div class="gallery-lib">
  <div class="gallery-lib-header card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
          <div class="text-uppercase text-primary fw-semibold small mb-1">Media Library</div>
          <h1 class="h4 fw-bold mb-1">Thư viện ảnh</h1>
          <p class="text-body-secondary mb-0 small">
            Tạo thư mục (1 cấp) → chọn thư mục → upload ảnh vào đúng thư mục đó.
            Tên file nên không dấu, dùng <code>_</code> giữa các từ.
          </p>
        </div>
        <button type="button" id="openFolderModal" class="btn btn-primary">
          <i class="fa-solid fa-folder-plus me-2"></i>Tạo thư mục
        </button>
      </div>
    </div>
  </div>

  <% if (typeof formError !== 'undefined' && formError) { %>
  <div class="alert alert-danger"><%= formError %></div>
  <% } %>

  <div class="row g-4">
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm gallery-lib-sidebar h-100">
        <div class="card-header bg-transparent border-bottom py-3 d-flex justify-content-between align-items-center">
          <strong class="small text-uppercase text-body-secondary">Thư mục</strong>
          <span class="badge text-bg-light border"><%= folders.length %></span>
        </div>
        <div class="card-body p-2">
          <div id="folderList" class="gallery-lib-folder-list">
            <% if (!folders.length) { %>
            <div class="gallery-lib-empty-folders text-center text-body-secondary py-4 px-2">
              <i class="fa-regular fa-folder-open fa-2x mb-2 opacity-50"></i>
              <p class="small mb-2">Chưa có thư mục nào.</p>
              <button type="button" class="btn btn-sm btn-outline-primary" data-open-folder-modal>
                Tạo thư mục đầu tiên
              </button>
            </div>
            <% } else { folders.forEach(function(folder) {
              const isActive = selectedFolderId === folder.id;
            %>
            <button
              type="button"
              class="gallery-lib-folder-item w-100 <%= isActive ? 'is-active' : '' %>"
              data-folder-id="<%= folder.id %>"
              data-folder-name="<%= folder.name %>"
            >
              <span class="gallery-lib-folder-icon"><i class="fa-solid fa-folder"></i></span>
              <span class="gallery-lib-folder-name text-truncate"><%= folder.name %></span>
              <span
                class="gallery-lib-folder-delete"
                data-del="<%= folder.id %>"
                title="Xóa thư mục"
                role="button"
                tabindex="0"
              ><i class="fa-solid fa-trash-can"></i></span>
            </button>
            <% }); } %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="card border-0 shadow-sm gallery-lib-main h-100">
        <% if (!selectedFolder) { %>
        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5 px-4">
          <i class="fa-solid fa-images fa-3x text-body-secondary opacity-25 mb-3"></i>
          <h2 class="h5 mb-2">Chưa chọn thư mục</h2>
          <p class="text-body-secondary small mb-3">Tạo thư mục trước, sau đó chọn thư mục để xem và upload ảnh.</p>
          <button type="button" class="btn btn-primary" data-open-folder-modal>
            <i class="fa-solid fa-folder-plus me-2"></i>Tạo thư mục
          </button>
        </div>
        <% } else { %>
        <div class="card-header bg-transparent border-bottom py-3">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
              <div class="small text-body-secondary mb-1">Đang xem</div>
              <h2 class="h5 mb-0 d-flex align-items-center gap-2">
                <i class="fa-solid fa-folder-open text-warning"></i>
                <span id="activeFolderName"><%= selectedFolder.name %></span>
              </h2>
            </div>
            <div class="gallery-lib-upload-toolbar d-flex flex-wrap align-items-center gap-2">
              <label class="small text-body-secondary mb-0" for="uploadFolderSelect">Upload vào</label>
              <select id="uploadFolderSelect" class="form-select form-select-sm gallery-lib-folder-select">
                <% folders.forEach(function(folder) { %>
                <option value="<%= folder.id %>" <%= selectedFolderId === folder.id ? 'selected' : '' %>><%= folder.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
        </div>

        <div class="card-body p-4">
          <div
            id="uploadDropzone"
            class="gallery-lib-upload-zone mb-4"
            tabindex="0"
            role="button"
            aria-label="Chọn ảnh để upload"
          >
            <input type="file" id="uploadInput" class="d-none" accept="image/*">
            <div class="gallery-lib-upload-zone-inner text-center">
              <i class="fa-solid fa-cloud-arrow-up fa-2x text-primary mb-2"></i>
              <p class="mb-1 fw-semibold">Kéo thả ảnh vào đây hoặc bấm để chọn</p>
              <p class="small text-body-secondary mb-3">PNG, JPG, WEBP · tối đa 5MB · upload vào thư mục đã chọn</p>
              <button type="button" id="btnPickFile" class="btn btn-outline-primary btn-sm">Chọn ảnh</button>
              <button type="button" id="btnUpload" class="btn btn-primary btn-sm ms-2 d-none">Upload ngay</button>
              <div id="uploadFileName" class="small text-body-secondary mt-2"></div>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center mb-3">
            <strong class="small text-uppercase text-body-secondary">Ảnh trong thư mục</strong>
            <span id="imageCountBadge" class="badge text-bg-secondary"><%= images.length %> ảnh</span>
          </div>

          <div id="image_container" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-xl-5 g-3">
            <% if (!images.length) { %>
            <div class="col-12">
              <div class="gallery-lib-no-images text-center text-body-secondary py-5 rounded-3 border border-dashed">
                <i class="fa-regular fa-image fa-2x mb-2 opacity-50"></i>
                <p class="mb-0 small">Thư mục này chưa có ảnh. Upload ảnh đầu tiên ở trên.</p>
              </div>
            </div>
            <% } else { images.forEach(function(img) { %>
            <div class="col">
              <div class="gallery-lib-card admin-gallery-card card border-0 shadow-sm overflow-hidden h-100">
                <img src="/<%= img.path %>" alt="<%= img.name %>" loading="lazy" class="admin-gallery-img w-100">
                <div class="admin-gallery-overlay d-flex align-items-center justify-content-center gap-2">
                  <a href="/<%= img.path %>" target="_blank" rel="noopener" class="btn btn-sm btn-light">Xem</a>
                  <button type="button" data-id="<%= img.path %>" class="btn btn-sm btn-danger">Xóa</button>
                </div>
                <div class="gallery-lib-card-caption small text-truncate px-2 py-1" title="<%= img.name %>"><%= img.name %></div>
              </div>
            </div>
            <% }); } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<div id="folderModal" class="admin-modal d-none align-items-center justify-content-center" role="dialog" aria-modal="true">
  <div class="admin-modal-dialog bg-white rounded-3 shadow-lg p-4 position-relative">
    <h2 class="h5 fw-bold mb-1">Tạo thư mục mới</h2>
    <p class="small text-body-secondary mb-3">Chỉ hỗ trợ 1 cấp thư mục. Tên gợi ý: <code>phong_doi</code>, <code>logo_site</code></p>
    <label class="form-label small" for="folderNameInput">Tên thư mục</label>
    <input type="text" id="folderNameInput" class="form-control" placeholder="vd: banner_trang_chu" maxlength="120" autocomplete="off">
    <div id="folderModalError" class="small text-danger mt-2 d-none"></div>
    <div class="mt-4 d-flex justify-content-end gap-2">
      <button type="button" id="closeFolderModal" class="btn btn-light">Hủy</button>
      <button type="button" id="btnCreateFolder" class="btn btn-primary">Tạo thư mục</button>
    </div>
    <button type="button" id="closeFolderModalX" class="position-absolute admin-top-2 admin-right-5 btn btn-sm btn-light border-0" aria-label="Đóng">×</button>
  </div>
</div>

<script>
  window.__GALLERY_PAGE__ = {
    selectedFolderId: <%= selectedFolderId != null ? selectedFolderId : 'null' %>,
    folders: <%- JSON.stringify(folders.map(function(f) { return { id: f.id, name: f.name }; })) %>,
  };
</script>
<script src="/admin/js/gallery-page.js"></script>
