<div class="admin-page-head d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h2>Cơ sở lưu trú</h2>
    <p class="text-body-secondary mb-0 small">Quản lý bảng <code>properties</code></p>
  </div>
  <a href="/admin/properties/new" class="btn btn-primary btn-sm">
    <i class="fa-solid fa-plus me-1"></i> Thêm cơ sở
  </a>
</div>

<% if (flash === 'created') { %>
<div class="alert alert-success">Đã tạo cơ sở mới.</div>
<% } else if (flash === 'updated') { %>
<div class="alert alert-success">Đã cập nhật cơ sở.</div>
<% } else if (flash === 'deleted') { %>
<div class="alert alert-success">Đã xóa cơ sở.</div>
<% } else if (flash === 'notfound') { %>
<div class="alert alert-warning">Không tìm thấy cơ sở.</div>
<% } else if (flash === 'error') { %>
<div class="alert alert-danger"><%= typeof msg !== 'undefined' ? msg : 'Có lỗi xảy ra' %></div>
<% } %>
<% if (typeof formError !== 'undefined' && formError) { %>
<div class="alert alert-danger"><%= formError %></div>
<% } %>

<div class="card admin-card">
  <div class="card-header d-flex align-items-center justify-content-between">
    <strong>Danh sách</strong>
    <span class="badge text-bg-secondary"><%= properties.length %> mục</span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-striped mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Ảnh</th>
            <th>Tên / Slug</th>
            <th>Địa điểm</th>
            <th>Loại</th>
            <th>Giá từ</th>
            <th>TT</th>
            <th class="text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (!properties.length) { %>
          <tr><td colspan="8" class="text-center py-4 text-body-secondary">Chưa có dữ liệu</td></tr>
          <% } %>
          <% properties.forEach(function(p) { %>
          <tr>
            <td><%= p.id %></td>
            <td>
              <% if (p.heroImageUrl) { %>
              <img src="<%= p.heroImageUrl %>" alt="" class="admin-table-thumb">
              <% } else { %>—<% } %>
            </td>
            <td>
              <strong><%= p.name %></strong><br>
              <code class="small"><%= p.slug %></code>
            </td>
            <td><%= p.city %><br><small class="text-body-secondary"><%= p.region %></small></td>
            <td><span class="badge badge-kind-<%= p.kind %>"><%= kindLabel(p.kind) %></span></td>
            <td><%= Number(p.priceFromVnd).toLocaleString('vi-VN') %> ₫</td>
            <td>
              <% if (p.isActive) { %><span class="badge bg-success">On</span><% } else { %><span class="badge bg-secondary">Off</span><% } %>
            </td>
            <td class="text-end text-nowrap">
              <a href="/admin/properties/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
              <form method="POST" action="/admin/properties/<%= p.id %>/delete" class="d-inline" onsubmit="return confirm('Xóa cơ sở này?');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
