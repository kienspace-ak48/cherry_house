<div class="admin-page-head d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h2>SEO &amp; Meta</h2>
    <p class="text-body-secondary mb-0 small">
      Cấu hình title, mô tả, Open Graph và robots cho website. Dùng biến <code>{{siteName}}</code>, <code>{{propertyName}}</code>… trong mẫu trang động.
    </p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a class="btn btn-outline-secondary btn-sm" href="/robots.txt" target="_blank" rel="noopener">robots.txt</a>
    <a class="btn btn-outline-secondary btn-sm" href="/sitemap.xml" target="_blank" rel="noopener">sitemap.xml</a>
    <a class="btn btn-outline-primary btn-sm" href="/" target="_blank" rel="noopener">Mở website</a>
  </div>
</div>

<% if (typeof flash !== 'undefined' && flash === 'global_saved') { %>
<div class="alert alert-success">Đã lưu cấu hình SEO toàn site.</div>
<% } else if (typeof flash !== 'undefined' && flash === 'page_saved') { %>
<div class="alert alert-success">Đã lưu mẫu SEO cho trang.</div>
<% } else if (typeof flash !== 'undefined' && flash === 'error') { %>
<div class="alert alert-danger"><%= msg || 'Có lỗi xảy ra' %></div>
<% } %>

<div class="row g-4">
  <div class="col-lg-5">
    <form method="POST" action="/admin/seo/global" class="admin-crud-form">
      <div class="card admin-card mb-4">
        <div class="card-header py-3"><strong>Cấu hình chung</strong></div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label" for="siteName">Tên website</label>
            <input class="form-control" id="siteName" name="siteName" value="<%= globalSettings.siteName %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="siteUrl">URL chính thức (canonical base)</label>
            <input class="form-control" id="siteUrl" name="siteUrl" value="<%= globalSettings.siteUrl %>" required placeholder="<%= typeof suggestedSiteUrl !== 'undefined' ? suggestedSiteUrl : 'http://localhost:8080' %>">
            <div class="form-text">
              Dùng cho canonical, Open Graph, sitemap.
              <strong>Không dùng</strong> <code>localhost:5173</code> (chỉ Vite dev).
              Local build: <code>http://localhost:8080</code> · Production: <code>https://kienvu.io.vn</code>.
              <% if (typeof clientAppUrl !== 'undefined' && clientAppUrl) { %>
              <br>OAuth/redirect hiện tại: <code><%= clientAppUrl %></code>
              <% if (typeof suggestedSiteUrl !== 'undefined' && suggestedSiteUrl && suggestedSiteUrl !== clientAppUrl) { %>
              · Gợi ý SEO: <code><%= suggestedSiteUrl %></code>
              <% } %>
              <% } %>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label" for="defaultTitle">Title mặc định</label>
            <input class="form-control" id="defaultTitle" name="defaultTitle" value="<%= globalSettings.defaultTitle %>" required maxlength="255">
          </div>
          <div class="mb-3">
            <label class="form-label" for="defaultDescription">Mô tả mặc định</label>
            <textarea class="form-control" id="defaultDescription" name="defaultDescription" rows="3" required><%= globalSettings.defaultDescription %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label" for="defaultKeywords">Keywords mặc định</label>
            <input class="form-control" id="defaultKeywords" name="defaultKeywords" value="<%= globalSettings.defaultKeywords || '' %>" placeholder="từ khóa, cách nhau bởi dấu phẩy">
          </div>
          <div class="mb-3">
            <%- include('../../partials/admin/galleryImagePicker', {
              fieldId: 'ogImageUrl',
              fieldName: 'ogImageUrl',
              value: globalSettings.ogImageUrl || '',
              label: 'Ảnh OG mặc định',
            }) %>
            <div class="form-text mt-1">Khuyến nghị <strong>1200×630 px, định dạng JPG hoặc PNG</strong>. Zalo/Facebook <strong>không</strong> hiển thị preview với AVIF/WebP — nếu upload AVIF vào Gallery, hãy chuyển sang JPG trước khi chọn làm OG.</div>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="themeColor">Theme color</label>
              <input class="form-control" id="themeColor" name="themeColor" value="<%= globalSettings.themeColor || '#9f1239' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label" for="twitterSite">Twitter @site</label>
              <input class="form-control" id="twitterSite" name="twitterSite" value="<%= globalSettings.twitterSite || '' %>" placeholder="@cherryhouse">
            </div>
          </div>
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" id="allowIndexing" name="allowIndexing" value="1" <%= globalSettings.allowIndexing ? 'checked' : '' %>>
            <label class="form-check-label" for="allowIndexing">Cho phép Google index (robots.txt)</label>
          </div>
        </div>
      </div>

      <div class="card admin-card mb-4">
        <div class="card-header py-3"><strong>Organization (JSON-LD)</strong></div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label" for="organizationName">Tên tổ chức</label>
            <input class="form-control" id="organizationName" name="organizationName" value="<%= globalSettings.organizationName || '' %>">
          </div>
          <div class="mb-3">
            <label class="form-label" for="organizationDescription">Mô tả tổ chức</label>
            <textarea class="form-control" id="organizationDescription" name="organizationDescription" rows="2"><%= globalSettings.organizationDescription || '' %></textarea>
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="organizationPhone">Điện thoại</label>
              <input class="form-control" id="organizationPhone" name="organizationPhone" value="<%= globalSettings.organizationPhone || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label" for="organizationEmail">Email</label>
              <input class="form-control" id="organizationEmail" name="organizationEmail" value="<%= globalSettings.organizationEmail || '' %>">
            </div>
          </div>
          <div class="mt-3">
            <label class="form-label" for="organizationAddress">Địa chỉ</label>
            <input class="form-control" id="organizationAddress" name="organizationAddress" value="<%= globalSettings.organizationAddress || '' %>">
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-primary">Lưu cấu hình chung</button>
    </form>
  </div>

  <div class="col-lg-7">
    <div class="card admin-card mb-3">
      <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <strong>Mẫu theo trang</strong>
        <span class="badge text-bg-secondary"><%= pages.length %> trang</span>
      </div>
      <div class="list-group list-group-flush">
        <% pages.forEach(function(page) { %>
        <a
          href="/admin/seo?page=<%= encodeURIComponent(page.pageKey) %>"
          class="list-group-item list-group-item-action d-flex justify-content-between align-items-center<%= editKey === page.pageKey ? ' active' : '' %>"
        >
          <div>
            <div class="fw-semibold"><%= page.label %></div>
            <div class="small text-body-secondary"><code><%= page.pageKey %></code> · <%= page.robots %></div>
          </div>
          <% if (!page.isActive) { %><span class="badge text-bg-warning">Tắt</span><% } %>
        </a>
        <% }); %>
      </div>
    </div>

    <% if (editingPage) { %>
    <form method="POST" action="/admin/seo/pages/<%= editingPage.pageKey %>" class="admin-crud-form">
      <div class="card admin-card">
        <div class="card-header py-3">
          <strong>Sửa: <%= editingPage.label %></strong>
          <span class="text-body-secondary small ms-2">(<code><%= editingPage.pageKey %></code>)</span>
        </div>
        <div class="card-body">
          <div class="alert alert-light border small mb-3">
            Biến có thể dùng:
            <% placeholders.forEach(function(ph, idx) { %>
            <code class="me-1"><%= ph %></code><%= idx < placeholders.length - 1 ? ',' : '' %>
            <% }); %>
          </div>
          <div class="mb-3">
            <label class="form-label" for="label">Nhãn hiển thị (admin)</label>
            <input class="form-control" id="label" name="label" value="<%= editingPage.label %>" required>
          </div>
          <div class="mb-3">
            <label class="form-label" for="titleTemplate">Title template</label>
            <input class="form-control" id="titleTemplate" name="titleTemplate" value="<%= editingPage.titleTemplate %>" required maxlength="255">
          </div>
          <div class="mb-3">
            <label class="form-label" for="descriptionTemplate">Description template</label>
            <textarea class="form-control" id="descriptionTemplate" name="descriptionTemplate" rows="3" required><%= editingPage.descriptionTemplate %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label" for="keywordsTemplate">Keywords template</label>
            <input class="form-control" id="keywordsTemplate" name="keywordsTemplate" value="<%= editingPage.keywordsTemplate || '' %>">
          </div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="robots">Robots</label>
              <select class="form-select" id="robots" name="robots">
                <option value="index, follow" <%= editingPage.robots === 'index, follow' ? 'selected' : '' %>>index, follow</option>
                <option value="noindex, nofollow" <%= editingPage.robots === 'noindex, nofollow' ? 'selected' : '' %>>noindex, nofollow</option>
                <option value="noindex, follow" <%= editingPage.robots === 'noindex, follow' ? 'selected' : '' %>>noindex, follow</option>
              </select>
            </div>
            <div class="col-md-6">
              <%- include('../../partials/admin/galleryImagePicker', {
                fieldId: 'pageOgImageUrl',
                fieldName: 'ogImageUrl',
                value: editingPage.ogImageUrl || '',
                label: 'Ảnh OG riêng',
              }) %>
              <div class="form-text">Để trống = dùng ảnh OG chung.</div>
            </div>
          </div>
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="1" <%= editingPage.isActive ? 'checked' : '' %>>
            <label class="form-check-label" for="isActive">Bật mẫu này</label>
          </div>
        </div>
        <div class="card-footer">
          <button type="submit" class="btn btn-primary">Lưu mẫu trang</button>
        </div>
      </div>
    </form>
    <% } else { %>
    <div class="card admin-card">
      <div class="card-body text-center text-body-secondary py-5">
        Chọn một trang bên trái để chỉnh title, mô tả và robots.
      </div>
    </div>
    <% } %>
  </div>
</div>
