<div class="admin-page-head d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h2>Chi nhánh</h2>
    <p class="text-body-secondary mb-0 small">
      Mỗi <strong>chi nhánh</strong> thuộc một <strong>cơ sở lưu trú</strong> — khách chọn cơ sở trước, rồi chọn chi nhánh khi đặt phòng.
    </p>
  </div>
  <a
    href="/admin/branches/new<%= filterPropertyId ? '?propertyId=' + filterPropertyId : '' %>"
    class="btn btn-primary btn-sm"
  >
    <i class="fa-solid fa-plus me-1"></i>
    <%= filterPropertyId && selectedProperty ? 'Thêm chi nhánh cho ' + selectedProperty.name : 'Thêm chi nhánh' %>
  </a>
</div>

<div class="admin-hierarchy-hint card admin-card mb-4">
  <div class="card-body py-3 d-flex flex-wrap align-items-center gap-3">
    <div class="admin-hierarchy-chain d-flex flex-wrap align-items-center gap-2 small">
      <span class="admin-hierarchy-step">
        <i class="fa-solid fa-building text-primary"></i>
        <strong>Cơ sở</strong>
        <span class="text-body-secondary">properties</span>
      </span>
      <i class="fa-solid fa-chevron-right text-body-secondary admin-hierarchy-arrow"></i>
      <span class="admin-hierarchy-step admin-hierarchy-step--active">
        <i class="fa-solid fa-store text-primary"></i>
        <strong>Chi nhánh</strong>
        <span class="text-body-secondary">branches</span>
      </span>
      <i class="fa-solid fa-chevron-right text-body-secondary admin-hierarchy-arrow"></i>
      <span class="admin-hierarchy-step">
        <i class="fa-solid fa-door-open text-body-secondary"></i>
        <strong>Phòng</strong>
        <span class="text-body-secondary">rooms</span>
      </span>
    </div>
    <div class="ms-md-auto text-body-secondary small">
      Tổng <strong><%= branches.length %></strong> chi nhánh · <strong><%= properties.length %></strong> cơ sở
    </div>
  </div>
</div>

<% if (flash === 'created') { %>
<div class="alert alert-success">Đã tạo chi nhánh mới.</div>
<% } else if (flash === 'updated') { %>
<div class="alert alert-success">Đã cập nhật chi nhánh.</div>
<% } else if (flash === 'deleted') { %>
<div class="alert alert-success">Đã xóa chi nhánh.</div>
<% } else if (flash === 'notfound') { %>
<div class="alert alert-warning">Không tìm thấy chi nhánh.</div>
<% } else if (flash === 'error') { %>
<div class="alert alert-danger"><%= typeof msg !== 'undefined' ? msg : 'Có lỗi xảy ra' %></div>
<% } %>
<% if (typeof formError !== 'undefined' && formError) { %>
<div class="alert alert-danger"><%= formError %></div>
<% } %>

<div class="card admin-card mb-4">
  <div class="card-body py-3">
    <form method="GET" action="/admin/branches" class="row g-2 align-items-end">
      <div class="col-md-6 col-lg-5">
        <label class="form-label small mb-1" for="filterPropertyId">Xem chi nhánh theo cơ sở</label>
        <select class="form-select form-select-sm" id="filterPropertyId" name="propertyId" onchange="this.form.submit()">
          <option value="">— Tất cả cơ sở (nhóm theo cơ sở) —</option>
          <% properties.forEach(function(prop) { %>
          <option value="<%= prop.id %>" <%= filterPropertyId === String(prop.id) ? 'selected' : '' %>>
            <%= prop.name %> · <%= prop.city %>
          </option>
          <% }); %>
        </select>
      </div>
      <div class="col-auto">
        <% if (filterPropertyId) { %>
        <a href="/admin/branches" class="btn btn-sm btn-outline-secondary">Xem tất cả cơ sở</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<% if (selectedProperty) { %>
<div class="card admin-card admin-property-context mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap gap-3 align-items-start">
      <% if (selectedProperty.heroImageUrl) { %>
      <img src="<%= selectedProperty.heroImageUrl %>" alt="" class="admin-property-context-thumb rounded">
      <% } %>
      <div class="flex-grow-1 min-w-0">
        <div class="text-body-secondary small mb-1">Đang xem chi nhánh thuộc cơ sở</div>
        <h3 class="h5 mb-1"><%= selectedProperty.name %></h3>
        <div class="d-flex flex-wrap gap-2 align-items-center small mb-2">
          <span><i class="fa-solid fa-location-dot me-1"></i><%= selectedProperty.city %></span>
          <code><%= selectedProperty.slug %></code>
          <span class="badge badge-kind-<%= selectedProperty.kind %>"><%= kindLabel(selectedProperty.kind) %></span>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a href="/admin/properties/<%= selectedProperty.id %>/edit" class="btn btn-sm btn-outline-primary">Sửa cơ sở</a>
          <a href="/admin/branches/new?propertyId=<%= selectedProperty.id %>" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-plus me-1"></i>Thêm chi nhánh
          </a>
        </div>
      </div>
      <div class="text-end">
        <div class="display-6 fw-bold text-primary lh-1"><%= branches.length %></div>
        <div class="small text-body-secondary">chi nhánh</div>
      </div>
    </div>
  </div>
</div>
<% } %>

<% if (!propertyGroups.length) { %>
<div class="card admin-card">
  <div class="card-body text-center py-5 text-body-secondary">
    <i class="fa-solid fa-store fa-2x mb-3 opacity-50"></i>
    <p class="mb-2">Chưa có cơ sở lưu trú nào.</p>
    <a href="/admin/properties/new" class="btn btn-sm btn-primary">Tạo cơ sở trước</a>
  </div>
</div>
<% } %>

<% propertyGroups.forEach(function(group) {
  const prop = group.property;
  const groupBranches = group.branches;
%>
<div class="card admin-card admin-branch-group mb-4">
  <div class="card-header admin-branch-group-header py-3">
    <div class="d-flex flex-wrap gap-3 align-items-center w-100">
      <% if (prop.heroImageUrl) { %>
      <img src="<%= prop.heroImageUrl %>" alt="" class="admin-branch-group-thumb rounded">
      <% } else { %>
      <div class="admin-branch-group-thumb admin-branch-group-thumb--placeholder rounded d-flex align-items-center justify-content-center">
        <i class="fa-solid fa-building text-body-secondary"></i>
      </div>
      <% } %>
      <div class="flex-grow-1 min-w-0">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
          <a href="/admin/branches?propertyId=<%= prop.id %>" class="h6 mb-0 text-decoration-none admin-branch-group-title">
            <%= prop.name %>
          </a>
          <span class="badge text-bg-light border">
            <%= groupBranches.length %> chi nhánh
          </span>
          <% if (!prop.isActive) { %><span class="badge bg-secondary">Cơ sở ẩn</span><% } %>
        </div>
        <div class="small text-body-secondary d-flex flex-wrap gap-2 align-items-center">
          <span><i class="fa-solid fa-location-dot me-1"></i><%= prop.city %></span>
          <code><%= prop.slug %></code>
          <span class="badge badge-kind-<%= prop.kind %>"><%= kindLabel(prop.kind) %></span>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2 ms-md-auto">
        <a href="/admin/properties/<%= prop.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Sửa cơ sở">
          <i class="fa-solid fa-pen-to-square me-1"></i>Cơ sở
        </a>
        <a href="/admin/branches/new?propertyId=<%= prop.id %>" class="btn btn-sm btn-outline-primary">
          <i class="fa-solid fa-plus me-1"></i>Chi nhánh
        </a>
      </div>
    </div>
  </div>

  <% if (!groupBranches.length) { %>
  <div class="card-body py-4 text-center text-body-secondary">
    <p class="mb-2 small">Cơ sở này chưa có chi nhánh nào.</p>
    <a href="/admin/branches/new?propertyId=<%= prop.id %>" class="btn btn-sm btn-primary">
      Thêm chi nhánh đầu tiên
    </a>
  </div>
  <% } else { %>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle admin-branch-group-table">
        <thead class="table-light">
          <tr>
            <th style="width:3rem"></th>
            <th>Chi nhánh</th>
            <th>Mã</th>
            <th>Địa chỉ</th>
            <th>Giá từ</th>
            <th>Phòng</th>
            <th>TT</th>
            <th class="text-end">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% groupBranches.forEach(function(b) { %>
          <tr>
            <td class="ps-3">
              <% if (b.imgUrl) { %>
              <img src="<%= b.imgUrl %>" alt="" class="admin-table-thumb">
              <% } else { %>
              <span class="admin-branch-row-icon text-body-secondary"><i class="fa-solid fa-store"></i></span>
              <% } %>
            </td>
            <td>
              <strong><%= b.name %></strong>
              <% if (b.tagline) { %><br><small class="text-body-secondary"><%= b.tagline %></small><% } %>
            </td>
            <td><code><%= b.code %></code></td>
            <td class="small"><%= b.address %></td>
            <td class="text-nowrap"><%= formatPriceVnd(b.price) %> ₫</td>
            <td>
              <a href="/admin/rooms?branchId=<%= b.id %>" class="badge text-bg-light border text-decoration-none">
                <%= b.roomCount %> phòng
              </a>
            </td>
            <td>
              <% if (b.isActive) { %><span class="badge bg-success">On</span><% } else { %><span class="badge bg-secondary">Off</span><% } %>
            </td>
            <td class="text-end text-nowrap pe-3">
              <a href="/admin/rooms?branchId=<%= b.id %>" class="btn btn-sm btn-outline-secondary" title="Danh sách phòng">Phòng</a>
              <a href="/admin/rooms/new?branchId=<%= b.id %>" class="btn btn-sm btn-outline-secondary" title="Thêm phòng">+</a>
              <a href="/admin/branches/<%= b.id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
              <form method="POST" action="/admin/branches/<%= b.id %>/delete" class="d-inline" onsubmit="return confirm('Xóa chi nhánh này? Các phòng và đặt chỗ liên quan có thể bị ảnh hưởng.');">
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>
<% }); %>
