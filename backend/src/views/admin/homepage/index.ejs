<script src="/admin/js/admin-home-hero-page.js"></script>
<script src="/admin/js/admin-homepage-lists.js"></script>
<script>
  (function homepageSections() {
    const sectionMap = {
      hero: '#homepageHero',
      content: '#homepageContent',
      areas: '#homepageAreas',
      kinds: '#homepageKinds',
      reviews: '#homepageReviews',
      newsletter: '#homepageNewsletter',
    };

    function syncToggle(trigger, target) {
      if (!trigger || !target) return;
      trigger.setAttribute('aria-expanded', target.classList.contains('show') ? 'true' : 'false');
    }

    function openSection(key, scroll) {
      const selector = sectionMap[key];
      if (!selector) return;
      const target = document.querySelector(selector);
      const card = document.querySelector(`[data-home-section="${key}"]`);
      const trigger = card ? card.querySelector('[data-admin-collapse]') : null;
      if (!target) return;
      target.classList.add('show');
      syncToggle(trigger, target);
      if (scroll && card) {
        card.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    document.querySelectorAll('[data-admin-collapse]').forEach((trigger) => {
      const selector = trigger.getAttribute('data-admin-collapse');
      const target = selector ? document.querySelector(selector) : null;
      if (!target) return;

      syncToggle(trigger, target);

      trigger.querySelectorAll('[data-collapse-ignore]').forEach((el) => {
        el.addEventListener('click', (event) => event.stopPropagation());
      });

      trigger.addEventListener('click', (event) => {
        if (event.target.closest('[data-collapse-ignore]')) return;
        event.preventDefault();
        target.classList.toggle('show');
        syncToggle(trigger, target);
      });
    });

    document.querySelectorAll('[data-home-nav]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.getAttribute('data-home-nav');
        openSection(key, true);
        if (key && sectionMap[key]) {
          history.replaceState(null, '', `#${key}`);
        }
      });
    });

    function expandAllSections() {
      document.querySelectorAll('#homepageForm .collapse').forEach((panel) => {
        panel.classList.add('show');
        const card = panel.closest('[data-home-section]');
        const trigger = card ? card.querySelector('[data-admin-collapse]') : null;
        syncToggle(trigger, panel);
      });
    }

    const form = document.getElementById('homepageForm');
    if (form) {
      form.addEventListener('submit', () => {
        expandAllSections();
      });
    }

    const hash = (window.location.hash || '').replace(/^#/, '');
    if (hash && sectionMap[hash]) {
      openSection(hash, true);
    }
  })();
</script>
