# Database
DATABASE_URL="mysql://root:password@localhost:3306/cherry_house"
# Tuỳ chọn — đường dẫn mysqldump nếu không có trong PATH (Windows: C:\Program Files\MySQL\...\mysqldump.exe)
# MYSQLDUMP_PATH="mysqldump"

# JWT — client React: access ngắn + refresh dài
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS="7"
# Admin CMS (cookie /admin): access token riêng, thường dài hơn client
JWT_ADMIN_ACCESS_EXPIRES_IN="3h"
# Legacy fallback nếu chưa set JWT_ACCESS_EXPIRES_IN
JWT_EXPIRES_IN="15m"

# Gmail SMTP — gửi OTP đăng ký
GMAIL_USER="your@gmail.com"
GMAIL_PASSWORD="app-password-here"

# Google OAuth (Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8080/api/auth/google/callback"

# Google AI Studio — chatbot trợ lý đặt phòng (https://aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_API_KEY=""
# Model — free tier 2026: dùng Flash-Lite (gemini-2.0-flash thường quota = 0)
GOOGLE_AI_MODEL="gemini-2.5-flash-lite"
# Tuỳ chọn — thử lần lượt khi hết quota model chính
# GOOGLE_AI_MODEL_FALLBACK="gemini-2.5-flash,gemini-2.0-flash-lite,gemini-1.5-flash"

# URL React — OAuth redirect sau đăng nhập Google
# Vite dev: http://localhost:5173 | Local build (Express): http://localhost:8080 | Production: https://kienvu.io.vn
CLIENT_APP_URL="http://localhost:5173"
# Tuỳ chọn — URL canonical/sitemap/OG (nếu khác CLIENT_APP_URL). Production: https://kienvu.io.vn
# PUBLIC_SITE_URL="https://kienvu.io.vn"

# Dev: trả OTP trong API khi chưa cấu hình Gmail (không dùng production)
AUTH_DEBUG_OTP="true"

# Flutter mobile: POST /api/auth/google/mobile { idToken } — dùng cùng GOOGLE_CLIENT_ID làm serverClientId
