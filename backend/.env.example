# Database
DATABASE_URL="mysql://root:password@localhost:3306/cherry_house"

# JWT — access ngắn + refresh dài (client React)
JWT_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS="7"
# Legacy fallback nếu chưa set JWT_ACCESS_EXPIRES_IN
JWT_EXPIRES_IN="15m"

# Gmail SMTP — gửi OTP đăng ký
GMAIL_USER="your@gmail.com"
GMAIL_PASSWORD="app-password-here"

# Google OAuth (Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8080/api/auth/google/callback"

# URL React dev / production
CLIENT_APP_URL="http://localhost:5173"

# Dev: trả OTP trong API khi chưa cấu hình Gmail (không dùng production)
AUTH_DEBUG_OTP="true"

# Flutter mobile: POST /api/auth/google/mobile { idToken } — dùng cùng GOOGLE_CLIENT_ID làm serverClientId
