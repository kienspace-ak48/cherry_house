generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Enum 
enum PropertyKind {
  homestay
  mini_hotel
  villa
  serviced_apartment
}

enum RoomCategory {
  Standard
  Deluxe
  Suite
  Penthouse
}

enum InventoryRoomStatus {
  available
  pending
  booked
}

enum BookingStatus {
  draft
  pending_payment
  confirmed
  checked_in
  cancelled
  completed
  no_show
}

enum PaymentMethod {
  card
  bank
  wallet
  momo
  cherry_wallet
}

enum WalletTransactionType {
  refund
  pay_booking
  admin_adjust
}

enum RefundPolicyCode {
  before_24h_full
  within_24h_none
  not_paid
  admin_override
}

enum RefundDestination {
  wallet
}

enum RefundStatus {
  completed
  skipped
}

enum CancelledBy {
  user
  admin
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum MembershipTier {
  standard
  gold
  diamond
}

enum PromoDiscountType {
  percent
  fixed_amount
}

enum AdminRole {
  admin
  super_admin
  staff
}

enum TokenSubject {
  client
  admin
}

enum AuthProvider {
  local
  google
}

// 1. properties
model Property {
  id           Int               @id @default(autoincrement())
  slug         String            @unique @db.VarChar(120)
  name         String            @db.VarChar(255)
  city         String            @db.VarChar(120)
  region       String            @db.VarChar(120)
  kind         PropertyKind
  tagline      String?           @db.VarChar(500)
  description  String            @db.Text
  address      String            @db.VarChar(500)
  priceFromVnd Int               @map("price_from_vnd")
  roomCount    Int               @default(0) @map("room_count")
  branchCount  Int               @default(0) @map("branch_count")
  rating       Decimal           @default(0) @db.Decimal(2, 1)
  reviewCount  Int               @default(0) @map("review_count")
  heroImageUrl String?           @map("hero_image_url") @db.VarChar(500)
  highlights   Json?
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  branches     Branch[]
  gallery      PropertyGallery[]
  amenities    PropertyAmenity[]
  bookings     Booking[]
  staffAdmins  Admin[]

  @@map("properties")
}

// 2. property_gallery
model PropertyGallery {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  imageUrl   String   @map("image_url") @db.VarChar(500)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_gallery")
}

// 3. branches
model Branch {
  id         Int            @id @default(autoincrement())
  propertyId Int            @map("property_id")
  code       String         @db.VarChar(100)
  name       String         @db.VarChar(100)
  address    String         @db.VarChar(200)
  tagline    String?        @db.VarChar(200)
  price      Decimal        @db.Decimal(10, 2)
  roomCount  Int            @default(0) @map("room_count")
  imgUrl     String?        @map("img_url") @db.VarChar(500)
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  mapPin     BranchMapPin?
  rooms      InventoryRoom[]
  bookings   Booking[]
  staffAdmins Admin[]

  @@unique([propertyId, code])
  @@map("branches")
}

// 4. branch_map_pins
model BranchMapPin {
  id             Int     @id @default(autoincrement())
  branchId       Int     @unique @map("branch_id")
  lat            Decimal @db.Decimal(10, 7)
  lng            Decimal @db.Decimal(10, 7)
  zoom           Int     @default(15)
  label          String? @db.VarChar(120)
  pinBadge       String? @map("pin_badge") @db.VarChar(50)
  pinInfo        String? @map("pin_info") @db.VarChar(200)
  googleMapsUrl  String  @map("google_maps_url") @db.VarChar(500)
  embedUrl       String? @map("embed_url") @db.VarChar(500)
  branch         Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("branch_map_pins")
}

// 5. room_types
model RoomType {
  id            Int                @id @default(autoincrement())
  slug          String             @unique @db.VarChar(120)
  badge         String             @db.VarChar(120)
  title         String             @db.VarChar(255)
  category      RoomCategory
  areaSqm       Int                @map("area_sqm")
  bedLabel      String             @map("bed_label") @db.VarChar(120)
  capacityLabel String             @map("capacity_label") @db.VarChar(120)
  basePriceVnd  Int                @map("base_price_vnd")
  checkInTime   String             @default("14:00") @map("check_in_time") @db.VarChar(10)
  checkOutTime  String             @default("12:00") @map("check_out_time") @db.VarChar(10)
  paragraphs    Json?
  policyBullets Json?              @map("policy_bullets")
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  gallery       RoomTypeGallery[]
  amenities     RoomTypeAmenity[]
  rooms         InventoryRoom[]

  @@map("room_types")
}

// 6. room_type_gallery
model RoomTypeGallery {
  id         Int      @id @default(autoincrement())
  roomTypeId Int      @map("room_type_id")
  imageUrl   String   @map("image_url") @db.VarChar(500)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

  @@index([roomTypeId])
  @@map("room_type_gallery")
}

// 7. amenities
model Amenity {
  id         Int               @id @default(autoincrement())
  icon       String            @db.VarChar(80)
  label      String            @db.VarChar(200)
  createdAt  DateTime          @default(now()) @map("created_at")
  properties PropertyAmenity[]
  roomTypes  RoomTypeAmenity[]

  @@map("amenities")
}

// 8. property_amenities
model PropertyAmenity {
  propertyId Int      @map("property_id")
  amenityId  Int      @map("amenity_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

// 9. room_type_amenities
model RoomTypeAmenity {
  roomTypeId Int      @map("room_type_id")
  amenityId  Int      @map("amenity_id")
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenity    Amenity  @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomTypeId, amenityId])
  @@map("room_type_amenities")
}

// 10. rooms (phòng vật lý)
model InventoryRoom {
  id          Int                 @id @default(autoincrement())
  branchId    Int                 @map("branch_id")
  roomTypeId  Int                 @map("room_type_id")
  code        String              @db.VarChar(50)
  priceVnd    Int                 @map("price_vnd")
  description      String  @db.Text
  extraParagraphs  Json?   @map("extra_paragraphs")
  imageUrl         String? @map("image_url") @db.VarChar(500)
  galleryImages    Json?   @map("gallery_images")
  altText     String?             @map("alt_text") @db.VarChar(255)
  maxAdults   Int                 @default(2) @map("max_adults")
  maxChildren Int                 @default(0) @map("max_children")
  status      InventoryRoomStatus @default(available)
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  branch      Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomType    RoomType            @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  bookings    Booking[]

  @@unique([branchId, code])
  @@map("rooms")
}

// 11. users — chỉ khách (đặt phòng, React app)
model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique @db.VarChar(255)
  passwordHash   String?        @map("password_hash") @db.VarChar(255)
  fullName       String         @map("full_name") @db.VarChar(255)
  avatarUrl      String?        @map("avatar_url") @db.VarChar(500)
  phone          String?        @db.VarChar(30)
  membershipTier MembershipTier @default(standard) @map("membership_tier")
  authProvider   AuthProvider   @default(local) @map("auth_provider")
  googleId       String?        @unique @map("google_id") @db.VarChar(120)
  emailVerified    Boolean        @default(false) @map("email_verified")
  isActive         Boolean        @default(true) @map("is_active")
  bookingBanned    Boolean        @default(false) @map("booking_banned")
  bookingBanReason String?        @map("booking_ban_reason") @db.Text
  bookingBannedAt  DateTime?      @map("booking_banned_at")
  profileMeta      Json?          @map("profile_meta")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  bookings       Booking[]
  refreshTokens  RefreshToken[]
  wallet         UserWallet?
  walletTransactions WalletTransaction[]

  @@map("users")
}

// Quản trị viên — tách bảng, đăng nhập /admin
model Admin {
  id            Int            @id @default(autoincrement())
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  fullName      String         @map("full_name") @db.VarChar(255)
  avatarUrl     String?        @map("avatar_url") @db.VarChar(500)
  role          AdminRole      @default(admin)
  branchId      Int?           @map("branch_id")
  propertyId    Int?           @map("property_id")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  branch          Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  property        Property?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  refreshTokens   RefreshToken[]
  bookingCheckIns BookingCheckIn[]

  @@index([branchId])
  @@index([propertyId])
  @@map("admins")
}

// Refresh token (client hoặc admin) — lưu hash, có thể revoke
model RefreshToken {
  id          Int          @id @default(autoincrement())
  tokenHash   String       @unique @map("token_hash") @db.VarChar(64)
  subjectType TokenSubject @map("subject_type")
  userId      Int?         @map("user_id")
  adminId     Int?         @map("admin_id")
  expiresAt   DateTime     @map("expires_at")
  revokedAt   DateTime?    @map("revoked_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin       Admin?       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Đăng ký email — OTP tạm (chưa tạo user cho đến khi verify)
model RegistrationOtp {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  otpHash      String   @map("otp_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(255)
  phone        String?  @db.VarChar(30)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("registration_otps")
}

// 12. bookings
model Booking {
  id              Int           @id @default(autoincrement())
  bookingCode     String        @unique @map("booking_code") @db.VarChar(40)
  userId          Int?          @map("user_id")
  roomId          Int           @map("room_id")
  propertyId      Int           @map("property_id")
  branchId        Int           @map("branch_id")
  roomTypeId      Int           @map("room_type_id")
  roomCode        String        @map("room_code") @db.VarChar(50)
  propertyName    String        @map("property_name") @db.VarChar(255)
  branchName      String        @map("branch_name") @db.VarChar(255)
  checkIn         DateTime      @map("check_in") @db.Date
  checkOut        DateTime      @map("check_out") @db.Date
  nights          Int
  adults          Int           @default(2)
  children        Int           @default(0)
  guestName       String        @map("guest_name") @db.VarChar(255)
  guestPhone      String        @map("guest_phone") @db.VarChar(30)
  guestEmail      String        @map("guest_email") @db.VarChar(255)
  specialNote     String?       @map("special_note") @db.Text
  pricePerNightVnd Int          @map("price_per_night_vnd")
  subtotalVnd     Int           @map("subtotal_vnd")
  serviceFeeVnd   Int           @default(0) @map("service_fee_vnd")
  discountVnd     Int           @default(0) @map("discount_vnd")
  totalVnd        Int           @map("total_vnd")
  promoCode       String?       @map("promo_code") @db.VarChar(40)
  status          BookingStatus @default(pending_payment)
  holdExpiresAt   DateTime?     @map("hold_expires_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  room            InventoryRoom @relation(fields: [roomId], references: [id], onDelete: Restrict)
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Restrict)
  payment         Payment?
  checkInRecord   BookingCheckIn?
  refund          BookingRefund?
  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@map("bookings")
}

// 12c. user_wallets — số dư ví nội bộ Cherry House
model UserWallet {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique @map("user_id")
  balanceVnd  Int      @default(0) @map("balance_vnd")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_wallets")
}

// 12d. wallet_transactions — sổ cái ví (bất biến)
model WalletTransaction {
  id              Int                   @id @default(autoincrement())
  userId          Int                   @map("user_id")
  amountVnd       Int                   @map("amount_vnd")
  balanceAfterVnd Int                   @map("balance_after_vnd")
  type            WalletTransactionType
  bookingId       Int?                  @map("booking_id")
  note            String?               @db.VarChar(500)
  createdAt       DateTime              @default(now()) @map("created_at")
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking         Booking?              @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([bookingId])
  @@map("wallet_transactions")
}

// 12e. booking_refunds — audit hủy / hoàn tiền
model BookingRefund {
  id                 Int               @id @default(autoincrement())
  bookingId          Int               @unique @map("booking_id")
  userId             Int?              @map("user_id")
  refundPercent      Int               @map("refund_percent")
  refundAmountVnd    Int               @default(0) @map("refund_amount_vnd")
  policyCode         RefundPolicyCode  @map("policy_code")
  destination        RefundDestination @default(wallet)
  status             RefundStatus      @default(skipped)
  cancelledBy        CancelledBy       @map("cancelled_by")
  hoursBeforeCheckIn Decimal?          @map("hours_before_check_in") @db.Decimal(8, 2)
  createdAt          DateTime          @default(now()) @map("created_at")
  booking            Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("booking_refunds")
}

// 12b. booking_check_ins — chữ ký khách khi check-in tại lễ tân
model BookingCheckIn {
  id                 Int      @id @default(autoincrement())
  bookingId          Int      @unique @map("booking_id")
  userId             Int?     @map("user_id")
  guestName          String   @map("guest_name") @db.VarChar(255)
  guestPhone         String   @map("guest_phone") @db.VarChar(30)
  guestEmail         String   @map("guest_email") @db.VarChar(255)
  bookingCode        String   @map("booking_code") @db.VarChar(40)
  propertyName       String   @map("property_name") @db.VarChar(255)
  branchName         String   @map("branch_name") @db.VarChar(255)
  roomCode           String   @map("room_code") @db.VarChar(50)
  signaturePath      String   @map("signature_path") @db.VarChar(500)
  checkedInAt        DateTime @default(now()) @map("checked_in_at")
  checkedInByAdminId Int?     @map("checked_in_by_admin_id")
  staffName          String?  @map("staff_name") @db.VarChar(255)
  booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  admin              Admin?   @relation(fields: [checkedInByAdminId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([guestEmail])
  @@index([checkedInAt])
  @@map("booking_check_ins")
}

// 13. payments
model Payment {
  id          Int           @id @default(autoincrement())
  bookingId   Int           @unique @map("booking_id")
  method      PaymentMethod
  amountVnd   Int           @map("amount_vnd")
  status      PaymentStatus @default(pending)
  providerRef String?       @map("provider_ref") @db.VarChar(255)
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// 14. media_folders (admin media library)
model MediaFolder {
  id        Int          @id @default(autoincrement())
  name      String       @unique @db.VarChar(120)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  images    MediaImage[]

  @@map("media_folders")
}

// 15. media_images (admin media library)
model MediaImage {
  id        Int          @id @default(autoincrement())
  folderId  Int?         @map("folder_id")
  name      String       @db.VarChar(255)
  path      String       @unique @db.VarChar(500)
  mimeType  String?      @map("mime_type") @db.VarChar(100)
  sizeBytes Int?         @map("size_bytes")
  createdAt DateTime     @default(now()) @map("created_at")
  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@map("media_images")
}

// 16. seo_global_settings — cấu hình SEO toàn site (singleton id=1)
model SeoGlobalSettings {
  id                      Int      @id @default(1)
  siteName                String   @map("site_name") @db.VarChar(120)
  siteUrl                 String   @map("site_url") @db.VarChar(500)
  defaultTitle            String   @map("default_title") @db.VarChar(255)
  defaultDescription      String   @map("default_description") @db.Text
  defaultKeywords         String?  @map("default_keywords") @db.VarChar(500)
  ogImageUrl              String?  @map("og_image_url") @db.VarChar(500)
  twitterSite             String?  @map("twitter_site") @db.VarChar(120)
  themeColor              String?  @map("theme_color") @db.VarChar(20)
  organizationName        String?  @map("organization_name") @db.VarChar(255)
  organizationDescription String?  @map("organization_description") @db.Text
  organizationPhone       String?  @map("organization_phone") @db.VarChar(30)
  organizationEmail       String?  @map("organization_email") @db.VarChar(255)
  organizationAddress     String?  @map("organization_address") @db.VarChar(500)
  allowIndexing           Boolean  @default(true) @map("allow_indexing")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("seo_global_settings")
}

// 17. seo_page_templates — title/description theo từng loại trang
model SeoPageTemplate {
  id                  Int      @id @default(autoincrement())
  pageKey             String   @unique @map("page_key") @db.VarChar(60)
  label               String   @db.VarChar(120)
  titleTemplate       String   @map("title_template") @db.VarChar(255)
  descriptionTemplate String   @map("description_template") @db.Text
  keywordsTemplate    String?  @map("keywords_template") @db.VarChar(500)
  robots              String   @default("index, follow") @db.VarChar(40)
  ogImageUrl          String?  @map("og_image_url") @db.VarChar(500)
  sortOrder           Int      @default(0) @map("sort_order")
  isActive            Boolean  @default(true) @map("is_active")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("seo_page_templates")
}

// 18. home_hero_settings — banner trang chủ (singleton id=1)
model HomeHeroSettings {
  id               Int      @id @default(1)
  badgeText        String   @map("badge_text") @db.VarChar(255)
  titleLine1       String   @map("title_line1") @db.VarChar(255)
  titleLine2       String   @map("title_line2") @db.VarChar(255)
  description      String   @db.Text
  quickCitiesJson  String   @default("[]") @map("quick_cities_json") @db.Text
  slidesJson       String   @default("[]") @map("slides_json") @db.LongText
  slideIntervalSec Int      @default(6) @map("slide_interval_sec")
  isEnabled        Boolean  @default(true) @map("is_enabled")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("home_hero_settings")
}

// 19. home_page_settings — nội dung homepage (singleton id=1)
model HomePageSettings {
  id                Int      @id @default(1)
  statsEnabled      Boolean  @default(true) @map("stats_enabled")
  statsJson         String   @map("stats_json") @db.Text
  whyEnabled        Boolean  @default(true) @map("why_enabled")
  whyEyebrow        String   @map("why_eyebrow") @db.VarChar(120)
  whyTitle          String   @map("why_title") @db.VarChar(255)
  whyDescription    String   @map("why_description") @db.Text
  whyItemsJson      String   @map("why_items_json") @db.LongText
  areasEnabled      Boolean  @default(true) @map("areas_enabled")
  areasEyebrow      String   @map("areas_eyebrow") @db.VarChar(120)
  areasTitle        String   @map("areas_title") @db.VarChar(255)
  areasSeeAllLabel  String   @map("areas_see_all_label") @db.VarChar(80)
  areasSeeAllHref   String   @map("areas_see_all_href") @db.VarChar(500)
  areasJson         String   @map("areas_json") @db.LongText
  kindsEnabled      Boolean  @default(true) @map("kinds_enabled")
  kindsEyebrow      String   @map("kinds_eyebrow") @db.VarChar(120)
  kindsTitle        String   @map("kinds_title") @db.VarChar(255)
  kindsDescription  String   @map("kinds_description") @db.Text
  kindsJson         String   @map("kinds_json") @db.LongText
  reviewsEnabled    Boolean  @default(true) @map("reviews_enabled")
  reviewsEyebrow    String   @map("reviews_eyebrow") @db.VarChar(120)
  reviewsTitle      String   @map("reviews_title") @db.VarChar(255)
  reviewsJson       String   @map("reviews_json") @db.LongText
  newsletterEnabled       Boolean  @default(true) @map("newsletter_enabled")
  newsletterTitle         String   @map("newsletter_title") @db.VarChar(255)
  newsletterDescription   String   @map("newsletter_description") @db.Text
  newsletterPlaceholder   String   @map("newsletter_placeholder") @db.VarChar(120)
  newsletterButtonLabel   String   @map("newsletter_button_label") @db.VarChar(80)
  newsletterSuccessMessage String  @map("newsletter_success_message") @db.VarChar(255)
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("home_page_settings")
}

// 20. chat_bot_settings — prompt & lời chào chatbot (singleton id=1)
model ChatBotSettings {
  id             Int      @id @default(1)
  assistantName  String   @map("assistant_name") @db.VarChar(120)
  welcomeMessage String   @map("welcome_message") @db.Text
  systemPrompt   String   @map("system_prompt") @db.LongText
  isEnabled      Boolean  @default(true) @map("is_enabled")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("chat_bot_settings")
}

// Email templates — nội dung admin tùy chỉnh theo loại mail
model EmailTemplate {
  id          Int      @id @default(autoincrement())
  templateKey String   @unique @map("template_key") @db.VarChar(60)
  name        String   @db.VarChar(120)
  description String?  @db.Text
  subject     String   @db.VarChar(255)
  configJson  String   @map("config_json") @db.LongText
  isEnabled   Boolean  @default(true) @map("is_enabled")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// 19. promo_codes (mã giảm giá / coupon)
model PromoCode {
  id                Int               @id @default(autoincrement())
  code              String            @unique @db.VarChar(40)
  discountType      PromoDiscountType @default(percent) @map("discount_type")
  discountPercent   Int?              @map("discount_percent")
  discountAmountVnd Int?              @map("discount_amount_vnd")
  minSubtotalVnd    Int               @default(0) @map("min_subtotal_vnd")
  description       String?           @db.VarChar(500)
  validFrom         DateTime          @map("valid_from") @db.Date
  validTo           DateTime          @map("valid_to") @db.Date
  maxUses           Int?              @map("max_uses")
  usedCount         Int               @default(0) @map("used_count")
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@map("promo_codes")
}

enum ContactMessageStatus {
  new
  read
  replied
  archived
}

// Tin nhắn từ form /contact
model ContactMessage {
  id        Int                  @id @default(autoincrement())
  fullName  String               @map("full_name") @db.VarChar(255)
  email     String               @db.VarChar(255)
  phone     String?              @db.VarChar(30)
  message   String               @db.Text
  status    ContactMessageStatus @default(new)
  adminNote String?              @map("admin_note") @db.Text
  readAt    DateTime?            @map("read_at")
  ipAddress String?              @map("ip_address") @db.VarChar(64)
  userAgent String?              @map("user_agent") @db.VarChar(500)
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("contact_messages")
}
